#!/usr/bin/env python3
"""
Thin executable wrapper for attest.

Adds the repo root to sys.path so 'attest' works without installation.
"""
import os
import sys

# Ensure the repo root (parent of this script's directory) is on the path.
_repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

from attest.cli import main  # noqa: E402

sys.exit(main())
